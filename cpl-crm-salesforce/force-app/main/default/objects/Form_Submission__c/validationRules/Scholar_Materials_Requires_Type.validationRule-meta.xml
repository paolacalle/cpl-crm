<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Scholar_Materials_Requires_Type</fullName>
    <active>true</active>
    <description>Requires Scholar Finalist Materials submissions to specify which material type was submitted.</description>
    <errorConditionFormula>AND(
  $RecordType.Name = &quot;Scholar Finalist Materials&quot;,
  ISPICKVAL(Material_Submission_Type__c, &quot;&quot;)
)</errorConditionFormula>
    <errorDisplayField>Material_Submission_Type__c</errorDisplayField>
    <errorMessage>Select the material submission type.</errorMessage>
</ValidationRule>
