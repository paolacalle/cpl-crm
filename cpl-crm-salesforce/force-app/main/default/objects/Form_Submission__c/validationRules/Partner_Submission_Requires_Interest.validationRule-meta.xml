<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Partner_Submission_Requires_Interest</fullName>
    <active>false</active>
    <description>Requires partners to select an area of interest.</description>
    <errorConditionFormula>AND(
  $RecordType.Name = &quot;Partner Interest Submission&quot;,
  ISBLANK(Partner_Interest_Type__c)
)</errorConditionFormula>
    <errorDisplayField>Partner_Interest_Type__c</errorDisplayField>
    <errorMessage>Please select an area of interest for this Partner submission.</errorMessage>
</ValidationRule>
