<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status__c</fullName>
    <description>Derived status of the employment based on dates and current flag.</description>
    <externalId>false</externalId>
    <formula>IF(
  Is_Current__c,
  &quot;Current&quot;,
  IF(
    ISBLANK(End_Date__c),
    &quot;Unknown&quot;,
    &quot;Past&quot;
  )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Automatically displays whether the employment is current or past.</inlineHelpText>
    <label>Status</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
