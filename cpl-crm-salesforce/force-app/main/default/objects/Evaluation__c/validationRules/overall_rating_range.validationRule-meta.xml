<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>overall_rating_range</fullName>
    <active>true</active>
    <description>An overall rating must be between 1 - 5.</description>
    <errorConditionFormula>OR(
  Overall_Rating__c &lt; 1,
  Overall_Rating__c &gt; 5,
  MOD(Overall_Rating__c, 1) &lt;&gt; 0
)</errorConditionFormula>
    <errorDisplayField>Overall_Rating__c</errorDisplayField>
    <errorMessage>Overall Rating must be a whole number between 1 and 5.</errorMessage>
</ValidationRule>
